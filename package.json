{
  "name": "tranzito2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter tranzito-app dev",
    "build": "pnpm --filter tranzito-app build",
    "preview": "pnpm --filter tranzito-app preview",
    "dev:db": "docker-compose up -d postgres",
    "db:generate": "pnpm --filter @tranzito/db generate",
    "db:migrate": "pnpm --filter @tranzito/db migrate",
    "db:studio": "pnpm --filter @tranzito/db studio",
    "db:seed": "pnpm --filter @tranzito/db seed",
    "lint": "eslint .",
    "typecheck": "nuxi typecheck app"
  },
"devDependencies": {
  "@nuxt/eslint": "^0.5.0",
  "eslint": "^9.10.0",
  "typescript": "^5.5.0"
},
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
