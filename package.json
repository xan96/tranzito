{
  "name": "tranzitum",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter tranzitum-app dev",
    "build": "pnpm --filter tranzitum-app build",
    "preview": "pnpm --filter tranzitum-app preview",
    "dev:db": "docker-compose up -d postgres",
    "db:generate": "pnpm --filter @tranzitum/db generate",
    "db:migrate": "pnpm --filter @tranzitum/db migrate",
    "db:studio": "pnpm --filter @tranzitum/db studio",
    "db:seed": "pnpm --filter @tranzitum/db seed",
    "lint": "eslint .",
    "typecheck": "nuxi typecheck app"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.5.0",
    "@nuxt/fonts": "^0.14.0",
    "eslint": "^9.10.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
