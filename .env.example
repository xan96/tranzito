# ============================================================
#  Tranzito env template (локальная разработка)
# ============================================================
#
# Для локального `pnpm dev`: cp .env.example .env и поправь
# DATABASE_URL (docker compose поднимает postgres на 5432).
#
# Для прода используй .env.prod.example. См. DEPLOY.md.
# ============================================================


# --- Database (локально) ------------------------------------
DATABASE_URL=postgresql://tranzitum:tranzitum@localhost:5432/tranzitum


# --- Auth ---------------------------------------------------
# openssl rand -hex 32
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=7d


# --- Mail (SMTP) --------------------------------------------
# Отправка через любой SMTP-сервер. Для Yandex.Почты:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=465
#   SMTP_USER=ваш@yandex.ru
#   SMTP_PASSWORD=<пароль приложения>   # id.yandex.ru → Пароли приложений → Почта
#   MAIL_FROM="Tranzitum <ваш@yandex.ru>"   # должен совпадать с SMTP_USER
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=


# --- App ----------------------------------------------------
NUXT_PUBLIC_APP_URL=http://localhost:3000


# --- File uploads -------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760


# --- Admin --------------------------------------------------
# Email для начального админа (создаётся скриптом seed).
# После первого входа админ создаёт остальных юзеров через UI.
# Список активных админов для системных уведомлений берётся из БД
# (role=admin, is_active=true), а не из этой переменной.
ADMIN_EMAIL=admin@tranzitum.ru

# Пароль начального админа. Используется ТОЛЬКО при первом seed.
# Минимум 8 символов. После seed можно удалить из .env.
# openssl rand -base64 16
ADMIN_PASSWORD=change-me-min-8-chars
