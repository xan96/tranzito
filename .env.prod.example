# ============================================================
#  PROD env (кладётся в /opt/tranzitum/.env на сервере)
# ============================================================
#  cp /opt/tranzitum/.env.prod.example /opt/tranzitum/.env
#  nano /opt/tranzitum/.env
# ============================================================


# --- Compose identity ---------------------------------------
# Префикс имён контейнеров / volumes.
COMPOSE_PROJECT_NAME=tranzitum


# --- Domain / TLS -------------------------------------------
# Боевой домен (его обслуживает Caddy и на него выписывается cert).
DOMAIN=tranzitum.ru
# Email для уведомлений Let's Encrypt.
ACME_EMAIL=admin@tranzitum.ru


# --- Postgres (внутри compose-сети, наружу НЕ торчит) ------
POSTGRES_USER=tranzitum
# openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=tranzitum


# --- Auth ---------------------------------------------------
# openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RANDOM
JWT_EXPIRES_IN=7d


# --- Mail (SMTP) --------------------------------------------
# Отправка через SMTP. Пример — Yandex.Почта:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=465
#   SMTP_USER=noreply@tranzitum.ru      # ящик в Яндекс.Коннекте для домена
#   SMTP_PASSWORD=<пароль приложения>   # id.yandex.ru → Пароли приложений → Почта
#   MAIL_FROM="Tranzitum <noreply@tranzitum.ru>"   # должен совпадать с SMTP_USER
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=noreply@tranzitum.ru
SMTP_PASSWORD=CHANGE_ME
MAIL_FROM=Tranzitum <noreply@tranzitum.ru>


# --- App ----------------------------------------------------
NUXT_PUBLIC_APP_URL=https://tranzitum.ru


# --- Uploads ------------------------------------------------
MAX_FILE_SIZE=10485760


# --- Admin --------------------------------------------------
# Email начального админа (создаётся первым seed).
ADMIN_EMAIL=admin@tranzitum.ru
# Пароль начального админа — ТОЛЬКО для первого seed.
# Минимум 8 символов. После seed удалить из .env.
# openssl rand -base64 16
ADMIN_PASSWORD=CHANGE_ME_MIN_8_CHARS


# --- Backups ------------------------------------------------
BACKUP_KEEP_DAYS=14
